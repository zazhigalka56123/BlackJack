# По умолчанию фронт сам определяет адрес WS из хоста страницы
# (ws://<этот-хост>:8000/ws), поэтому для локального запуска ничего настраивать не нужно.
#
# Переопределить порт сервера (если меняли --port у uvicorn):
# VITE_SERVER_PORT=8000
#
# Либо задать весь URL целиком (имеет приоритет):
# VITE_WS_URL=ws://192.168.1.100:8000/ws
